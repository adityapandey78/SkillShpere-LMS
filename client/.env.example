# SkillSphere LMS client — environment variables (Vite needs the VITE_ prefix).
# Copy to .env (local) or set these in Vercel → Project → Settings → Environment Variables.

# Backend API base URL
VITE_API_URL=https://your-server.onrender.com

# ── Pulsar analytics (optional) ───────────────────────────────────
# Point these at your Pulsar host (e.g. your Tailscale Funnel URL or a real domain).
# Leave unset to disable tracking. The key is a publishable tracking key (not a secret).
VITE_PULSAR_SRC=https://your-pulsar-host/p.js
VITE_PULSAR_ENDPOINT=https://your-pulsar-host/api/v1/events
VITE_PULSAR_KEY=pk_your_lms_key
